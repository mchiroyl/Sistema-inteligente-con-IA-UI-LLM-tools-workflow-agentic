# ============================================================
# Support Intake AI — Configuración de Entorno
# ============================================================
# 1. Copie este archivo: cp .env.example .env  (Windows: copy .env.example .env)
# 2. Reemplace los valores con sus credenciales reales
# 3. NUNCA suba el archivo .env a GitHub
# ============================================================

# ─── OPCIÓN A: Groq (RECOMENDADO — rápido y gratuito) ────────────────────────
# Obtén tu clave en: https://console.groq.com/keys
OPENAI_API_KEY=gsk_REEMPLAZAR_CON_TU_GROQ_API_KEY
OPENAI_BASE_URL=https://api.groq.com/openai/v1

# Modelos Groq con soporte de tool calling (function calling):
# - llama-3.3-70b-versatile   ← RECOMENDADO (más capaz)
# - llama-3.1-70b-versatile
# - mixtral-8x7b-32768
LLM_MODEL=llama-3.3-70b-versatile

# ─── OPCIÓN B: OpenAI directo ─────────────────────────────────────────────────
# OPENAI_API_KEY=sk-REEMPLAZAR_CON_TU_CLAVE_OPENAI
# OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

